# InttelTrade AI — Environment Variables
# Copy this file to .env and fill in your values.

# Database (default: local SQLite — change to postgres for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/intellitrade
DATABASE_URL=sqlite:///./intellitrade.db

# JWT Secret — MUST be changed before production deployment
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
